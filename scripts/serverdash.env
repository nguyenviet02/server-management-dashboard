# ServerDash Environment Configuration
# This file is loaded by the systemd service

# Panel HTTP port
SERVERDASH_PORT=39921

# Data directory (database, Caddyfile, backups)
SERVERDASH_DATA_DIR=/var/lib/serverdash

# SQLite database path
SERVERDASH_DB_PATH=/var/lib/serverdash/serverdash.db

# !! IMPORTANT: Change this to a secure random string !!
SERVERDASH_JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# Path to Caddy binary
SERVERDASH_CADDY_BIN=/usr/bin/caddy

# Path to generated Caddyfile
SERVERDASH_CADDYFILE_PATH=/var/lib/serverdash/Caddyfile

# Log directory
SERVERDASH_LOG_DIR=/var/log/serverdash

# Caddy admin API URL
SERVERDASH_ADMIN_API=http://localhost:2019
